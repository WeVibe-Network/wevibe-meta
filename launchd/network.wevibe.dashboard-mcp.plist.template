<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>network.wevibe.dashboard-mcp</string>

  <key>ProgramArguments</key>
  <array>
    <string>__NODE_BIN__</string>
    <string>__WORKSPACE_ROOT__/wevibe-mcp/dist/dashboard-server.js</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__WORKSPACE_ROOT__/wevibe-mcp</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>WEVIBE_HUB_URL</key>
    <string>http://localhost:4440</string>
    <key>WEVIBE_OLLAMA_URL</key>
    <string>http://localhost:11434</string>
    <key>WEVIBE_DASHBOARD_PORT</key>
    <string>4451</string>
    <key>WEVIBE_GUARD_BIN</key>
    <string>__WORKSPACE_ROOT__/wevibe-guard/target/release/wevibe-guard</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>__WORKSPACE_ROOT__/wevibe-meta/.logs/dashboard-mcp.log</string>

  <key>StandardErrorPath</key>
  <string>__WORKSPACE_ROOT__/wevibe-meta/.logs/dashboard-mcp.log</string>
</dict>
</plist>
